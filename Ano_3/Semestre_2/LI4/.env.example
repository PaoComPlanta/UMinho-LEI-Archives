# =============================================================
# TAKI — Variáveis de Ambiente (template)
# =============================================================
# Copia este ficheiro para .env e preenche com os teus valores:
#
#   cp .env.example .env
#
# O ficheiro .env está no .gitignore — NUNCA o commites.
# Consulta keys/README.md para instruções de geração das chaves.
# =============================================================

# Chave pública RSA (RS256) em Base64 — usada para verificar JWTs
# Gerar: base64 -w 0 public_key.pem > public_key.b64  &&  cat public_key.b64
TAKI_JWT_PUBLIC_KEY=<cole_aqui_o_conteudo_de_public_key.b64>

# Chave privada RSA (RS256) em Base64 — usada para assinar JWTs
# Gerar: base64 -w 0 private_key.pem > private_key.b64  &&  cat private_key.b64
TAKI_JWT_PRIVATE_KEY=<cole_aqui_o_conteudo_de_private_key.b64>

# Role do nó (local = só API local, central = API local + global)
APP_MODE=central

# Configuração de BD para execução local com Docker Compose
TAKI_DB_URL=jdbc:postgresql://localhost:5433/taki_local_db
TAKI_DB_USER=admin
TAKI_DB_PASSWORD=password123

# Opcional: portas da API local/global (se não definires, usa 8080/8081)
TAKI_LOCAL_API_PORT=8080
TAKI_GLOBAL_API_PORT=8081

# Alvo de proxy do frontend em desenvolvimento
VITE_LOCAL_API_TARGET=http://localhost:8080
VITE_GLOBAL_API_TARGET=http://localhost:8081

# Configuração de CORS para o Frontend Remoto
TAKI_CORS_ORIGIN=http://localhost:5173
