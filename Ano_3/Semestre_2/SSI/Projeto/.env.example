# .env - Configuration for the Secure Chat Server
# This file contains settings for the server deployer.

# -- Server Network Configuration --
# Host and port for the server to listen on.
SERVER_HOST=127.0.0.1
SERVER_PORT=9999

# -- Database Path Configuration --
# Path to the server's SQLite database file.
DB_PATH_SERVER=server_data.db

# Default path for the client's SQLite database.
DB_PATH_CLIENT=client_data.db
